{
  "name": "@vskstudio/takt-angular",
  "version": "0.3.2",
  "description": "Idiomatic Angular wrapper for Takt privacy-friendly analytics",
  "license": "MIT",
  "author": "VSK Studio",
  "type": "module",
  "unpkg": "./dist/element/index.js",
  "jsdelivr": "./dist/element/index.js",
  "sideEffects": [
    "./dist/element/index.js"
  ],
  "keywords": [
    "analytics",
    "privacy",
    "angular",
    "takt"
  ],
  "homepage": "https://github.com/vskstudio/takt-angular#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vskstudio/takt-angular.git"
  },
  "bugs": {
    "url": "https://github.com/vskstudio/takt-angular/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm build:lib && pnpm build:element && node scripts/patch-dist-pkg.mjs",
    "build:lib": "ng-packagr -p ng-package.json",
    "build:element": "tsup",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "e2e": "playwright test",
    "size": "size-limit",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "@angular/common": ">=17",
    "@angular/core": ">=17",
    "@vskstudio/takt-core": ">=0.3.1"
  },
  "dependencies": {
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^1.10.0",
    "@analogjs/vitest-angular": "^1.10.0",
    "@angular/build": "^19.2.27",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.50.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^20.19.43",
    "@vskstudio/takt-core": "^0.3.2",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "ng-packagr": "^19.2.0",
    "rxjs": "^7.8.0",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "zone.js": "~0.15.0"
  },
  "packageManager": "pnpm@10.33.0"
}
